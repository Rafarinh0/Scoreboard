# Which event source to use: "simulated" (mock-events-api) or "real" (future).
EVENT_SOURCE=simulated

# Base URL of the mock-events-api (Stage 1).
MOCK_EVENTS_API_URL=http://localhost:4000

# Comma-separated match ids the poller should follow.
MATCH_IDS=42

# How often the poller asks the source for new events (milliseconds).
POLL_INTERVAL_MS=3000

# Redis connection (backs the BullMQ queue).
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB connection (persistent event history).
MONGO_URI=mongodb://localhost:27017/scoreboard
